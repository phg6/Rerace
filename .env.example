# Copy to .env.local and fill in. See README for where each value comes from.

NEXT_PUBLIC_SITE_URL=https://rerace.net

# Supabase > Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Supabase > Connect > Session pooler connection string (for Payload CMS)
DATABASE_URI=
# Any long random string
PAYLOAD_SECRET=

# resend.com API key (newsletters + session reminders)
RESEND_API_KEY=
EMAIL_FROM=Rerace <noreply@rerace.net>

# Any long random string; Vercel Cron sends it as a Bearer token
CRON_SECRET=

# Go-live announcements (optional)
DISCORD_WEBHOOK_URL=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=@rerace

# Web push (npx web-push generate-vapid-keys)
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:contact@rerace.net

# Vercel Blob (CMS image uploads)
BLOB_READ_WRITE_TOKEN=
